# Environment Configuration

# Dataset paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SPLITS_DIR=data/splits

# Model paths
MODELS_DIR=models
CHECKPOINTS_DIR=models/checkpoints
FINAL_MODELS_DIR=models/final
TFJS_MODELS_DIR=models/tfjs

# Training configuration
EPOCHS=50
BATCH_SIZE=32
LEARNING_RATE=0.0001
TRAIN_SPLIT=0.8
VAL_SPLIT=0.1
TEST_SPLIT=0.1

# Model configuration
MODEL_INPUT_SIZE=224
MODEL_OUTPUTS=3

# Inference
INFERENCE_BATCH_SIZE=16
INFERENCE_THRESHOLD=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=training.log

# Data processing
CACHE_METADATA=true
NUM_WORKERS=4
PIN_MEMORY=true

# Hardware
USE_GPU=true
DEVICE=cuda
